# White Label Configuration
# Customize these values to rebrand the application
NEXT_PUBLIC_APP_NAME=AppAgent
NEXT_PUBLIC_DOMAIN=app-agent.ai
NEXT_PUBLIC_TAGLINE=From ASO to Release, All Streamlined
NEXT_PUBLIC_DESCRIPTION=AppAgent automates ASO while simplifying every step from planning to release. Effortlessly generate multilingual release notes, track growth, and handle updates—all in one place. OSS alternative to AppTweak, App Radar, and Sensor Tower.
NEXT_PUBLIC_SUPPORT_EMAIL=support@app-agent.ai
NEXT_PUBLIC_INFO_EMAIL=info@app-agent.ai
NEXT_PUBLIC_MARKETING_EMAIL=shu@app-agent.ai
NEXT_PUBLIC_MARKETING_NAME=Shu from AppAgent
NEXT_PUBLIC_TWITTER_HANDLE=@ngo275

NEXTAUTH_SECRET=my-superstrong-secret
NEXTAUTH_URL=http://localhost:3000

NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_MARKETING_URL=http://localhost:3000

# Google client id and secret for authentication
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# This variable is from Resend to send emails
RESEND_API_KEY=

# This variable is from PostHog to track events
NEXT_PUBLIC_POSTHOG_KEY=

# LLM (default provider when a team has not configured one in-app)
# Backward compatible with OPENAI_API_KEY. Works with any OpenAI-compatible API.
OPENAI_API_KEY=
# LLM_API_KEY=
# LLM_BASE_URL=        # e.g. http://localhost:11434/v1 (Ollama) or https://openrouter.ai/api/v1
# LLM_MODEL=gpt-4o
# Optional: dedicated key used to encrypt team LLM API keys at rest.
# Falls back to NEXTAUTH_SECRET when unset.
# LLM_CONFIG_SECRET=

# Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Open-source mode: when true (the default), everything is free/unlimited and
# all billing/Stripe UI is hidden. Set to false to restore the paid plan flow.
NEXT_PUBLIC_OPEN_SOURCE=true

# Stripe (only needed when NEXT_PUBLIC_OPEN_SOURCE=false)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# Force-enable the free plan. Left implicit (true) while NEXT_PUBLIC_OPEN_SOURCE=true.
NEXT_PUBLIC_FREE_PLAN_ENABLED=true

# Database provider: "postgresql" (default) or "sqlite" for a local/desktop DB.
# After changing this, run `yarn db:setup` (also run automatically by dev/build).
DATABASE_PROVIDER=postgresql

# Postgres DB (used when DATABASE_PROVIDER=postgresql)
DATABASE_URL="postgresql://username:password@localhost:5432/dbname?schema=public"

# For SQLite instead, set DATABASE_PROVIDER=sqlite and use a file URL:
# DATABASE_PROVIDER=sqlite
# DATABASE_URL="file:./dev.db"

# Initial admin account, created by `yarn admin:create` (open-source mode).
# In open-source mode you can then sign in at /login with email + password,
# without configuring email (Resend) or Google OAuth.
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=Admin
ADMIN_PASSWORD=change-me
